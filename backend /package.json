{
  "name": "repo-devops-cicd-visualizer-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Repository + DevOps + CI/CD Visualizer Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,d.ts --exec ts-node --files src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "keywords": [
    "express",
    "typescript",
    "github-actions",
    "devops",
    "cicd"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "axios": "^1.8.4",
    "bullmq": "^5.48.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.7.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "unzipper": "^0.12.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.17",
    "@types/unzipper": "^0.10.11",
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}